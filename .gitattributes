# Force LF line endings for shell scripts (critical for gradlew on Linux)
gradlew text eol=lf
*.sh text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Binary files
*.jar binary
*.png binary
*.apk binary
*.zip binary
